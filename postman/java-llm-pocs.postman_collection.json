        {
          "name": "Policies & ACLs",
          "item": [
            {
              "name": "Set Bucket Policy",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"PublicRead\",\n      \"Effect\": \"Allow\",\n      \"Principal\": \"*\",\n      \"Action\": \"s3:GetObject\",\n      \"Resource\": \"arn:aws:s3:::{{bucket}}/public/*\"\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/s3/policies/policy?bucket={{bucket}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "policies", "policy"],
                  "query": [{ "key": "bucket", "value": "{{bucket}}" }]
