        {
          "name": "Multipart Upload",
          "item": [
            {
              "name": "Initiate Multipart Upload",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/multipart/initiate?bucket={{bucket}}&key=large-file.bin&contentType=application/octet-stream",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "multipart", "initiate"],
                  "query": [
                    { "key": "bucket", "value": "{{bucket}}" },
                    { "key": "key", "value": "large-file.bin" },
                    { "key": "contentType", "value": "application/octet-stream" }
                  ]
                }
              }
            },
            {
              "name": "Upload Part",
              "request": {
                "method": "PUT",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "bucket", "value": "{{bucket}}", "type": "text" },
                    { "key": "key", "value": "large-file.bin", "type": "text" },
                    { "key": "uploadId", "value": "UPLOAD_ID", "type": "text" },
                    { "key": "partNumber", "value": "1", "type": "text" },
                    { "key": "part", "type": "file", "src": "" }
                  ]
                },
                "url": {
                  "raw": "{{baseUrl}}/api/s3/multipart/upload-part",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "multipart", "upload-part"]
                }
