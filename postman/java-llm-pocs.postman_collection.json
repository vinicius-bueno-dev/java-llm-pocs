            {
              "name": "Set Object ACL",
              "request": {
                "method": "PUT",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/policies/acl/object?bucket={{bucket}}&key=test/hello.txt&cannedAcl=public-read",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "policies", "acl", "object"],
                  "query": [
                    { "key": "bucket", "value": "{{bucket}}" },
                    { "key": "key", "value": "test/hello.txt" },
                    { "key": "cannedAcl", "value": "public-read" }
                  ]
                }
              }
            },
            {
              "name": "Set Public Access Block",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
