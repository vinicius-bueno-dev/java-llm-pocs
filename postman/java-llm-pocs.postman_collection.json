              "name": "Abort Multipart Upload",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/multipart/abort?bucket={{bucket}}&key=large-file.bin&uploadId=UPLOAD_ID",
