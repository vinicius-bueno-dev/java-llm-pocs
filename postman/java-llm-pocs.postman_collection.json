                "url": {
                  "raw": "{{baseUrl}}/api/s3/objects/batch-delete?bucket={{bucket}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "objects", "batch-delete"],
                  "query": [{ "key": "bucket", "value": "{{bucket}}" }]
