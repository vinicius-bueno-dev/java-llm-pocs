              "name": "Set Bucket ACL",
              "request": {
                "method": "PUT",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/policies/acl/bucket?bucket={{bucket}}&cannedAcl=private",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "policies", "acl", "bucket"],
                  "query": [
                    { "key": "bucket", "value": "{{bucket}}" },
                    { "key": "cannedAcl", "value": "private" }
                  ]
                }
              }
            },
            {
              "name": "Get Bucket ACL",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/policies/acl/bucket?bucket={{bucket}}",
                  "host": ["{{baseUrl}}"],
