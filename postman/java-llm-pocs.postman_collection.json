{
  "info": {
    "name": "java-llm-pocs",
    "description": "Collection de endpoints para as POCs do projeto java-llm-pocs.\nTodas as POCs rodam com LocalStack (localhost:4566) e Spring Boot (localhost:8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "bucket",
      "value": "nameless-local-poc-storage",
      "type": "string"
    },
    {
      "key": "logsBucket",
      "value": "nameless-local-poc-logs",
      "type": "string"
    },
    {
      "key": "websiteBucket",
      "value": "nameless-local-poc-website",
      "type": "string"
    },
    {
      "key": "sqsQueueUrl",
      "value": "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/nameless-local-s3-events",
      "type": "string"
    },
    {
      "key": "sqsQueueArn",
      "value": "arn:aws:sqs:us-east-1:000000000000:nameless-local-s3-events",
      "type": "string"
    },
    {
      "key": "snsTopicArn",
      "value": "arn:aws:sns:us-east-1:000000000000:nameless-local-s3-events",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "poc-s3-storage",
      "description": "POC abrangente do S3 — 13 areas de feature com Spring Boot + AWS SDK v2 + LocalStack",
      "item": [
        {
          "name": "Bucket Operations",
          "item": [
            {
              "name": "Create Bucket",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/buckets?name=my-test-bucket",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "buckets"],
                  "query": [{ "key": "name", "value": "my-test-bucket" }]
                }
              }
            },
            {
              "name": "List Buckets",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/buckets",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "buckets"]
                }
              }
            },
            {
              "name": "Bucket Exists",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/buckets/{{bucket}}/exists",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "buckets", "{{bucket}}", "exists"]
                }
              }
            },
            {
              "name": "Delete Bucket",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/buckets/my-test-bucket",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "buckets", "my-test-bucket"]
                }
              }
            },
            {
              "name": "Get Bucket Location",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/s3/buckets/{{bucket}}/location",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "s3", "buckets", "{{bucket}}", "location"]
                }
              }
            }
          ]
        },
        {
          "name": "Object CRUD",
          "item": [
            {
              "name": "Upload Object",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "bucket", "value": "{{bucket}}", "type": "text" },
                    { "key": "key", "value": "test/hello.txt", "type": "text" },
                    { "key": "file", "type": "file", "src": "" }
